; File: graph3d.asc. Wireframe-oriented graph library for ZX Spectrum
; Forked from graph.asc as a 3D experimentation backend.

; dra_lin: draw a line in the screen
; from de = end1 (d = x-axis, e = y-axis)
; to   hl = end2 (h = x-axis, l = y-axis)
dra_lin
	; Bresenham line drawing, all octants.
	; Keep the public contract used by the compiler: DE=(x0,y0), HL=(x1,y1).
	ld a, d				;
	ld (lin_x0), a		;
	ld a, e				;
	ld (lin_y0), a		;
	ld a, h				;
	ld (lin_x1), a		;
	ld a, l				;
	ld (lin_y1), a		;
	xor a				;
	ld (lin_alt), a		;

	; dx = abs(x1 - x0), sx = +/-1
	ld a, h				;
	sub d				;
	jr nc, lin_xpo		;
	ld a, d				;
	sub h				;
	ld (lin_dx), a		;
	ld a, 255			; -1
	ld (lin_sx), a		;
	jr lin_ydl			;
lin_xpo
	ld (lin_dx), a		;
	ld a, 1				;
	ld (lin_sx), a		;

	; dy = abs(y1 - y0), sy = +/-1
lin_ydl
	ld a, l				;
	sub e				;
	jr nc, lin_ypo		;
	ld a, e				;
	sub l				;
	ld (lin_dy), a		;
	ld a, 255			; -1
	ld (lin_sy), a		;
	jp lin_fpa			;
lin_ypo
	ld (lin_dy), a		;
	ld a, 1				;
	ld (lin_sy), a		;

	; 3D wireframe fast paths -------------------------------------
lin_fpa
	ld a, (lin_dy)		;
	or a				;
	jp z, lin_hor		;
	ld a, (lin_dx)		;
	or a				;
	jp z, lin_ver		;
	ld b, a				;
	ld a, (lin_dy)		;
	cp b				;
	jp z, lin_dia		;

	; choose major axis
lin_cho
	ld a, (lin_dx)		;
	ld b, a				;
	ld a, (lin_dy)		;
	cp b				;
	jp c, lin_xma		; dx > dy
	jp z, lin_xma		; dx == dy
	jp lin_yma			; dy > dx

	; Horizontal line ---------------------------------------------
lin_hor
	ld a, (lin_x0)		;
	ld b, a				;
	ld a, (lin_x1)		;
	cp b				; x1 < x0?
	jr c, lin_hsw		;
	ld a, b				; left = x0
	ld (lin_hlf), a		;
	ld a, (lin_x1)		; right = x1
	ld (lin_hrg), a		;
	jr lin_hpr			;
lin_hsw
	ld (lin_hlf), a		; left = x1
	ld a, b				; right = x0
	ld (lin_hrg), a		;

lin_hpr
	ld a, (lin_hlf)		;
	and %00000111		;
	ld (lin_hlo), a		;
	ld a, (lin_hrg)		;
	and %00000111		;
	ld (lin_hro), a		;

	ld a, (lin_hlf)		;
	rrca				;
	rrca				;
	rrca				;
	and %00011111		;
	ld (lin_hlb), a		;
	ld a, (lin_hrg)		;
	rrca				;
	rrca				;
	rrca				;
	and %00011111		;
	ld (lin_hrb), a		;

	; HL = screen byte address for left pixel
	ld a, (lin_hlf)		;
	ld d, a				;
	ld a, (lin_y0)		;
	ld e, a				;
	ld a, e				;
	and %00000111   	;
	ld l, a				;
	or %01000000    	;
	ld h, a         	;
	ld a, e         	;
	rrca            	; 
	rrca				;
	rrca				;
	and %00011000   	;
	or h            	;
	ld h, a				;
	ld a, e				;
	rlca            	; 
	rlca				;
	and %11100000   	;
	ld l, a				;
	ld a, d				;
	rrca            	; 
	rrca				;
	rrca				;
	and %00011111  		;
	or l            	;
	ld l, a          	;
	call lin_buf			;

	ld a, (lin_hlb)		;
	ld b, a				;
	ld a, (lin_hrb)		;
	cp b				;
	jr nz, lin_hmu		;

	; Single-byte horizontal line: left mask & right mask.
	ld a, (lin_hlo)		;
	call lin_hlm		;
	ld b, a				;
	ld a, (lin_hro)		;
	call lin_hrm		;
	and b				;
	and %01010101		;
	or (hl)				;
	ld (hl), a			;
	ret					;

lin_hmu
	; First partial byte.
	ld a, (lin_hlo)		;
	call lin_hlm		;
	and %01010101		;
	or (hl)				;
	ld (hl), a			;
	inc hl				;

	; Full middle bytes.
	ld a, (lin_hrb)		;
	ld b, a				;
	ld a, (lin_hlb)		;
	ld c, a				;
	ld a, b				;
	sub c				;
	dec a				;
	jr z, lin_hen		;
	ld b, a				;
lin_hfl
	ld (hl), %01010101	;
	inc hl				;
	djnz lin_hfl		;

	; Last partial byte.
lin_hen
	ld a, (lin_hro)		;
	call lin_hrm		;
	and %01010101		;
	or (hl)				;
	ld (hl), a			;
	ret					;

lin_hlm
	ld de, hmskl		;
	add a, e			;
	ld e, a				;
	jr nc, lin_hl1		;
	inc d				;
lin_hl1
	ld a, (de)			;
	ret					;

lin_hrm
	ld de, hmskr		;
	add a, e			;
	ld e, a				;
	jr nc, lin_hr1		;
	inc d				;
lin_hr1
	ld a, (de)			;
	ret					;

	; Vertical line -----------------------------------------------
lin_ver
	; X is constant: calculate the screen byte and bit mask once, then walk
	; the ZX screen rows. This avoids calling lin_plo for every vertical pixel.
	ld a, (lin_x0)		;
	ld d, a				;
	and %00000111		;
	ld de, pixlis		;
	add a, e			;
	ld e, a				;
	jr nc, lin_vms1		;
	inc d				;
lin_vms1
	ld a, (de)			;
	ld (lin_vms), a		;

	; HL = screen byte address for (x0, y0).
	ld a, (lin_x0)		;
	ld d, a				;
	ld a, (lin_y0)		;
	ld e, a				;
	ld a, e				;
	and %00000111   	;
	ld l, a				;
	or %01000000    	;
	ld h, a         	;
	ld a, e         	;
	rrca            	;
	rrca				;
	rrca				;
	and %00011000   	;
	or h            	;
	ld h, a				;
	ld a, e				;
	rlca            	;
	rlca				;
	and %11100000   	;
	ld l, a				;
	ld a, d				;
	rrca            	;
	rrca				;
	rrca				;
	and %00011111  		;
	or l            	;
	ld l, a          	;
	call lin_buf			;

	ld a, (lin_dy)		;
	inc a				;
	ld b, a				; inclusive pixel count
	ld a, (lin_sy)		;
	cp 1				;
	jr z, lin_vdn		;

lin_vup
	ld a, (lin_alt)		;
	xor 1				;
	ld (lin_alt), a		;
	or a				;
	jr z, lin_vusk		;
	ld a, (lin_vms)		;
	or (hl)				;
	ld (hl), a			;
lin_vusk
	ld a, h				;
	and %00000111		;
	jr z, lin_vub		;
	dec h				;
	jr lin_vus			;
lin_vub
	ld a, l				;
	sub 32				;
	ld l, a				;
	jr c, lin_vuc		;
	ld a, h				;
	add a, 7			;
	ld h, a				;
	jr lin_vus			;
lin_vuc
	ld a, h				;
	sub 1				;
	ld h, a				;
lin_vus
	djnz lin_vup		;
	ret					;

lin_vdn
	ld a, (lin_alt)		;
	xor 1				;
	ld (lin_alt), a		;
	or a				;
	jr z, lin_vdsk		;
	ld a, (lin_vms)		;
	or (hl)				;
	ld (hl), a			;
lin_vdsk
	inc h				;
	ld a, h				;
	and %00000111		;
	jr nz, lin_vds		;
	ld a, l				;
	add a, 32			;
	ld l, a				;
	jr c, lin_vds		;
	ld a, h				;
	sub 8				;
	ld h, a				;
lin_vds
	djnz lin_vdn		;
	ret					;

lin_nrw
	inc h				;
	ld a, h				;
	and %00000111		;
	ret nz				;
	ld a, l				;
	add a, 32			;
	ld l, a				;
	ret c				;
	ld a, h				;
	sub 8				;
	ld h, a				;
	ret					;

lin_prw
	ld a, h				;
	and %00000111		;
	jr z, lin_prb		;
	dec h				;
	ret					;
lin_prb
	ld a, l				;
	sub 32				;
	ld l, a				;
	jr c, lin_prc		;
	ld a, h				;
	add a, 7			;
	ld h, a				;
	ret					;
lin_prc
	ld a, h				;
	sub 1				;
	ld h, a				;
	ret					;

	; Perfect diagonal --------------------------------------------
lin_dia
	; Perfect diagonals move one pixel in X for each screen row. Calculate the
	; initial address/mask once, then update the mask and row address directly.
	ld a, (lin_x0)		;
	ld d, a				;
	and %00000111		;
	ld de, pixlis		;
	add a, e			;
	ld e, a				;
	jr nc, lin_dms1		;
	inc d				;
lin_dms1
	ld a, (de)			;
	ld (lin_vms), a		;

	; HL = screen byte address for (x0, y0).
	ld a, (lin_x0)		;
	ld d, a				;
	ld a, (lin_y0)		;
	ld e, a				;
	ld a, e				;
	and %00000111   	;
	ld l, a				;
	or %01000000    	;
	ld h, a         	;
	ld a, e         	;
	rrca            	;
	rrca				;
	rrca				;
	and %00011000   	;
	or h            	;
	ld h, a				;
	ld a, e				;
	rlca            	;
	rlca				;
	and %11100000   	;
	ld l, a				;
	ld a, d				;
	rrca            	;
	rrca				;
	rrca				;
	and %00011111  		;
	or l            	;
	ld l, a          	;
	call lin_buf			;

	ld a, (lin_dx)		;
	inc a				;
	ld b, a				; inclusive pixel count
	ld a, (lin_sy)		;
	cp 1				;
	jr z, lin_ddn		;

lin_dup
	ld a, (lin_alt)		;
	xor 1				;
	ld (lin_alt), a		;
	or a				;
	jr z, lin_dusk		;
	ld a, (lin_vms)		;
	or (hl)				;
	ld (hl), a			;
lin_dusk
	djnz lin_dus		;
	ret					;
lin_dus
	ld a, h				;
	and %00000111		;
	jr z, lin_dub		;
	dec h				;
	jr lin_duy			;
lin_dub
	ld a, l				;
	sub 32				;
	ld l, a				;
	jr c, lin_duc		;
	ld a, h				;
	add a, 7			;
	ld h, a				;
	jr lin_duy			;
lin_duc
	ld a, h				;
	sub 1				;
	ld h, a				;
lin_duy
	ld a, (lin_sx)		;
	cp 1				;
	jr z, lin_dxr		;
	jr lin_dxl			;

lin_ddn
	ld a, (lin_alt)		;
	xor 1				;
	ld (lin_alt), a		;
	or a				;
	jr z, lin_ddsk		;
	ld a, (lin_vms)		;
	or (hl)				;
	ld (hl), a			;
lin_ddsk
	djnz lin_dds		;
	ret					;
lin_dds
	inc h				;
	ld a, h				;
	and %00000111		;
	jr nz, lin_ddy		;
	ld a, l				;
	add a, 32			;
	ld l, a				;
	jr c, lin_ddy		;
	ld a, h				;
	sub 8				;
	ld h, a				;
lin_ddy
	ld a, (lin_sx)		;
	cp 1				;
	jr z, lin_dxr		;
	jr lin_dxl			;

lin_dxr
	ld a, (lin_vms)		;
	srl a				;
	jr nz, lin_dxrs		;
	ld a, %10000000		;
	inc l				;
lin_dxrs
	ld (lin_vms), a		;
	ld a, (lin_sy)		;
	cp 1				;
	jp z, lin_ddn		;
	jp lin_dup			;

lin_dxl
	ld a, (lin_vms)		;
	sla a				;
	jr nc, lin_dxls		;
	ld a, %00000001		;
	dec l				;
lin_dxls
	ld (lin_vms), a		;
	ld a, (lin_sy)		;
	cp 1				;
	jp z, lin_ddn		;
	jp lin_dup			;

	; X-major line ------------------------------------------------
lin_xma
	ld a, (lin_dx)		;
	srl a				;
	ld l, a				;
	ld h, 0				;
	ld (lin_err), hl	;
lin_xlo
	call lin_plo		;
	ld a, (lin_x0)		;
	ld b, a				;
	ld a, (lin_x1)		;
	cp b				;
	ret z				;

	; x0 += sx
	ld a, (lin_sx)		;
	cp 1				;
	ld a, (lin_x0)		;
	jr z, lin_xip		;
	dec a				;
	jr lin_xss			;
lin_xip
	inc a				;
lin_xss
	ld (lin_x0), a		;

	ld hl, (lin_err)	;
	ld a, (lin_dy)		;
	ld c, a				;
	ld b, 0				;
	or a				;
	sbc hl, bc			; err -= dy
	ld (lin_err), hl	;
	bit 7, h			;
	jr z, lin_xlo		;

	; y0 += sy
	ld a, (lin_sy)		;
	cp 1				;
	ld a, (lin_y0)		;
	jr z, lin_yip		;
	dec a				;
	jr lin_yss			;
lin_yip
	inc a				;
lin_yss
	ld (lin_y0), a		;
	ld hl, (lin_err)	;
	ld a, (lin_dx)		;
	ld c, a				;
	ld b, 0				;
	add hl, bc			; err += dx
	ld (lin_err), hl	;
	jr lin_xlo			;

	; Y-major line ------------------------------------------------
lin_yma
	ld a, (lin_dy)		;
	srl a				;
	ld l, a				;
	ld h, 0				;
	ld (lin_err), hl	;
lin_ylo
	call lin_plo		;
	ld a, (lin_y0)		;
	ld b, a				;
	ld a, (lin_y1)		;
	cp b				;
	ret z				;

	; y0 += sy
	ld a, (lin_sy)		;
	cp 1				;
	ld a, (lin_y0)		;
	jr z, lin_yip2		;
	dec a				;
	jr lin_yss2		;
lin_yip2
	inc a				;
lin_yss2
	ld (lin_y0), a		;

	ld hl, (lin_err)	;
	ld a, (lin_dx)		;
	ld c, a				;
	ld b, 0				;
	or a				;
	sbc hl, bc			; err -= dx
	ld (lin_err), hl	;
	bit 7, h			;
	jr z, lin_ylo		;

	; x0 += sx
	ld a, (lin_sx)		;
	cp 1				;
	ld a, (lin_x0)		;
	jr z, lin_xip2		;
	dec a				;
	jr lin_xss2		;
lin_xip2
	inc a				;
lin_xss2
	ld (lin_x0), a		;
	ld hl, (lin_err)	;
	ld a, (lin_dy)		;
	ld c, a				;
	ld b, 0				;
	add hl, bc			; err += dy
	ld (lin_err), hl	;
	jr lin_ylo			;

lin_plo
	ld a, (lin_alt)		;
	xor 1				;
	ld (lin_alt), a		;
	or a				;
	ret z				;
	ld a, (lin_y0)		;
	ld e, a				;
	; Fast plot for dra_lin. It intentionally clobbers DE and HL because
	; Bresenham keeps its loop state in memory and reloads it after plotting.
	; screen row base via lookup table, then add x byte offset.
	ld l, e				;
	ld h, 0				;
	add hl, hl			;
	ld de, scradr		;
	add hl, de			;
	ld e, (hl)			;
	inc hl				;
	ld h, (hl)			;
	ld l, e				;
	ld a, (lin_x0)		; A= xxxxxxxx
	rrca            	; 
	rrca				;
	rrca				; A= 000xxxxx 
	and %00011111  		; mask out bits, rrca takes carry
	add a, l			;
	ld l, a          	; store in l
	call lin_buf			;

	; x2-x1-x0, find bit in byte via lookup (11B)
	ld a, (lin_x0)		; A= xxxxxbbb
	and %00000111		; A= 00000bbb

	ld de, pixlis		; point at bit list
	add a, e			; point at base + x 3-bit indicator
	ld e, a				;
	ld a, (de)			; read bit value
	or (hl)				; A= 000b0000 || screen
	ld (hl), a			; back to memory screen
	ret					;

; Framebuffer target switch. dra_lin still calculates a normal ZX screen
; address; when enabled, lin_buf maps &4000..&4fff to FB_ADDR..FB_ADDR+&0fff.
fb_draw_buffer
	ld a, 1				;
	ld (lin_tgt), a		;
	ret					;

fb_draw_screen
	xor a				;
	ld (lin_tgt), a		;
	ret					;

fb_target_on
	jp fb_draw_buffer		;

fb_target_off
	jp fb_draw_screen		;

lin_buf
	ld a, (lin_tgt)		;
	or a				;
	ret z				;
	ld a, h				;
	add a, &90			;
	ld h, a				;
	ret					;

lin_x0 defb 0
lin_y0 defb 0
lin_x1 defb 0
lin_y1 defb 0
lin_dx defb 0
lin_dy defb 0
lin_sx defb 0
lin_sy defb 0
lin_err defw 0
lin_hlf defb 0
lin_hrg defb 0
lin_hlo defb 0
lin_hro defb 0
lin_hlb defb 0
lin_hrb defb 0
lin_vms defb 0
lin_alt defb 0
lin_tgt defb 0
clr_x defb 0
clr_y defb 0
clr_w defb 0
clr_h defb 0
clr_x2 defb 0
clr_yc defb 0
clr_hc defb 0
clr_lbyte defb 0

hmskl
defb %11111111
defb %01111111
defb %00111111
defb %00011111
defb %00001111
defb %00000111
defb %00000011
defb %00000001

hmskr
defb %10000000
defb %11000000
defb %11100000
defb %11110000
defb %11111000
defb %11111100
defb %11111110
defb %11111111

; plo_poi: plot point in screen
; D=x E=y, canvas-compatible coordinates: y=0 is the top of the screen
; target: 0 1 0 y7 y6 y2 y1 y0  |  y5 y4 y3 x7 x7 x5 x4 x3
plo_poi
	push hl				; save registers
	push de				;
	
	; skip every 2nd point (5B)
	;ld a, d			; mix X an Y
	;add a, e			;
	;rra				; check bit 0
	;jr nc, lincon
	
	; y2-y1-y0 (7B)
	ld a, e				; A= yyyyyyyy
	and %00000111   	; A= 00000yyy
	ld l, a				; L= 00000bbb
	
	or %01000000    	; A= 01000yyy
	ld h, a         	; H= 01000yyy
	
	; y7-y6 (8B)
	ld a, e         	; A= yyyyyyyy
	rrca            	; 
	rrca				;
	rrca				; A= 000yyyyy
	and %00011000   	; A= 000yy000
	or h            	; A= 010yyyyy
	ld h, a				; H= 010yyyyy
	
	; y5-y4-y3 (6B)
	ld a, e				; A= yyyyyyyy
	rlca            	; 
	rlca				; A= yyyyyy00
	and %11100000   	; A= yyy00000
	ld l, a				; A= yyy00000
	
	; x7-x6-x5-x4-x3 (8B)
	ld a, d				; A= xxxxxxxx
	rrca            	; 
	rrca				;
	rrca				; A= 000xxxxx 
	and %00011111  		; mask out bits, rrca takes carry
	or l            	; A= yyyxxxxx
	ld l, a          	; store in l
	
	; x2-x1-x0, find bit in byte via lookup (11B)
	ld a, d				; A= xxxxxbbb
	and %00000111		; A= 00000bbb
	
	ld de, pixlis		; point at bit list
	add a, e			; point at base + x 3-bit indicator
	ld e, a				;
	ld a, (de)			; read bit value
	or (hl)				; A= 000b0000 || screen
	ld (hl), a			; back to memory screen

lincon	pop de			; recover registers
	pop hl				;
	ret

scradr
defw &4000, &4100, &4200, &4300, &4400, &4500, &4600, &4700
defw &4020, &4120, &4220, &4320, &4420, &4520, &4620, &4720
defw &4040, &4140, &4240, &4340, &4440, &4540, &4640, &4740
defw &4060, &4160, &4260, &4360, &4460, &4560, &4660, &4760
defw &4080, &4180, &4280, &4380, &4480, &4580, &4680, &4780
defw &40A0, &41A0, &42A0, &43A0, &44A0, &45A0, &46A0, &47A0
defw &40C0, &41C0, &42C0, &43C0, &44C0, &45C0, &46C0, &47C0
defw &40E0, &41E0, &42E0, &43E0, &44E0, &45E0, &46E0, &47E0
defw &4800, &4900, &4A00, &4B00, &4C00, &4D00, &4E00, &4F00
defw &4820, &4920, &4A20, &4B20, &4C20, &4D20, &4E20, &4F20
defw &4840, &4940, &4A40, &4B40, &4C40, &4D40, &4E40, &4F40
defw &4860, &4960, &4A60, &4B60, &4C60, &4D60, &4E60, &4F60
defw &4880, &4980, &4A80, &4B80, &4C80, &4D80, &4E80, &4F80
defw &48A0, &49A0, &4AA0, &4BA0, &4CA0, &4DA0, &4EA0, &4FA0
defw &48C0, &49C0, &4AC0, &4BC0, &4CC0, &4DC0, &4EC0, &4FC0
defw &48E0, &49E0, &4AE0, &4BE0, &4CE0, &4DE0, &4EE0, &4FE0
defw &5000, &5100, &5200, &5300, &5400, &5500, &5600, &5700
defw &5020, &5120, &5220, &5320, &5420, &5520, &5620, &5720
defw &5040, &5140, &5240, &5340, &5440, &5540, &5640, &5740
defw &5060, &5160, &5260, &5360, &5460, &5560, &5660, &5760
defw &5080, &5180, &5280, &5380, &5480, &5580, &5680, &5780
defw &50A0, &51A0, &52A0, &53A0, &54A0, &55A0, &56A0, &57A0
defw &50C0, &51C0, &52C0, &53C0, &54C0, &55C0, &56C0, &57C0
defw &50E0, &51E0, &52E0, &53E0, &54E0, &55E0, &56E0, &57E0

pixlis					; pending: it might overflow if sitting at the end of a page.
defb %10000000
defb %01000000
defb %00100000
defb %00010000
defb %00001000
defb %00000100
defb %00000010
defb %00000001

; cle_rec: clear rectangle.
; Input is stored by the translator in clr_x, clr_y, clr_w, clr_h.
cle_rec
	ld a, (clr_w)			;
	or a					;
	ret z					;
	ld a, (clr_h)			;
	or a					;
	ret z					;
	ld (clr_hc), a			;
	ld a, (clr_w)			;
	dec a					;
	ld b, a					;
	ld a, (clr_x)			;
	add a, b				;
	jr nc, clr_x2_ok		;
	ld a, 255				;
clr_x2_ok
	ld (clr_x2), a			;
	ld a, (clr_y)			;
	ld (clr_yc), a			;

clr_row_loop
	ld a, (clr_hc)			;
	or a					;
	ret z					;
	ld a, (clr_yc)			;
	cp 192					;
	ret nc					;
	ld l, a					;
	ld h, 0					;
	add hl, hl				;
	ld de, scradr			;
	add hl, de				;
	ld e, (hl)				;
	inc hl					;
	ld d, (hl)				;
	ex de, hl				;
	ld a, (clr_x)			;
	rrca					;
	rrca					;
	rrca					;
	and %00011111			;
	ld c, a					;
	ld (clr_lbyte), a		;
	ld a, (clr_x2)			;
	rrca					;
	rrca					;
	rrca					;
	and %00011111			;
	ld b, a					;
	ld a, l					;
	add a, c				;
	ld l, a					;
	ld a, b					;
	cp c					;
	jr nz, clr_multi_byte	;

clr_single_byte
	push hl					;
	ld a, (clr_x)			;
	and %00000111			;
	ld e, a					;
	ld d, 0					;
	ld hl, hmskl			;
	add hl, de				;
	ld b, (hl)				;
	ld a, (clr_x2)			;
	and %00000111			;
	ld e, a					;
	ld hl, hmskr			;
	add hl, de				;
	ld a, (hl)				;
	and b					;
	pop hl					;
	cpl						;
	and (hl)				;
	ld (hl), a				;
	jr clr_next_row			;

clr_multi_byte
	push hl					;
	ld a, (clr_x)			;
	and %00000111			;
	ld e, a					;
	ld d, 0					;
	ld hl, hmskl			;
	add hl, de				;
	ld a, (hl)				;
	pop hl					;
	cpl						;
	and (hl)				;
	ld (hl), a				;
	inc hl					;
	ld a, (clr_x2)			;
	rrca					;
	rrca					;
	rrca					;
	and %00011111			;
	ld b, a					;
	ld a, (clr_lbyte)		;
	ld c, a					;
	ld a, b					;
	sub c					;
	dec a					;
	jr z, clr_right_byte	;
	ld b, a					;
clr_middle_loop
	ld (hl), 0				;
	inc hl					;
	djnz clr_middle_loop	;

clr_right_byte
	push hl					;
	ld a, (clr_x2)			;
	and %00000111			;
	ld e, a					;
	ld d, 0					;
	ld hl, hmskr			;
	add hl, de				;
	ld a, (hl)				;
	pop hl					;
	cpl						;
	and (hl)				;
	ld (hl), a				;

clr_next_row
	ld hl, clr_yc			;
	inc (hl)				;
	ld hl, clr_hc			;
	dec (hl)				;
	jp clr_row_loop			;

; cle_scr: clear screen 
; unrolling code using a faster than regular method.
cle_scr	
	ld (stack + 1), sp  	; store current stack pointer
	ld hl, &0000           	; this value will be stored on stack
	ld sp, &4000 + &1800	; 16384 + 6144
	ld b, l            	; set B to 0. it causes that DJNZ will repeat 256 times

loop1	push hl             	; store HL on stack (2 bytes)
	push hl             	; 2B x 12 pushes
	push hl             	; 
	push hl			;
	push hl			;
	push hl			;
	push hl			;
	push hl			;
	push hl			;
	push hl			;
	push hl			;
	push hl			;
	djnz loop1          	; inner loop repeats 256 times

stack	ld sp, 0            	; 0  overwritten by first instruction
	ret

; cle_trd0 / cle_trd1: clear the first or second ZX screen third.
; Each third is 2K. 128 iterations * 8 pushes * 2 bytes = 2048 bytes.
cle_trd0
	ld (trd_stk + 1), sp	;
	ld hl, &0000			;
	ld sp, &4800			; end of first third (&4000..&47ff)
	jr cle_trd				;

cle_trd1
	ld (trd_stk + 1), sp	;
	ld hl, &0000			;
	ld sp, &5000			; end of second third (&4800..&4fff)

cle_trd
	ld b, 128				;
trd_loop
	push hl					;
	push hl					;
	push hl					;
	push hl					;
	push hl					;
	push hl					;
	push hl					;
	push hl					;
	djnz trd_loop			;

trd_stk	ld sp, 0				;
	ret						;

; Experimental 3D frame buffer helpers.
; fb_copy_2thirds copies 4K from FB_ADDR to the first two screen thirds.
; Conservative byte copy with HL=source and DE=destination.
FB_ADDR equ &D000

fb_copy_2thirds
	ld hl, FB_ADDR			; source buffer
	ld de, &4000			; destination screen memory
	ld bc, &1000			; 4096 bytes
fb_cpy_loop
	ld a, (hl)				;
	ld (de), a				;
	inc hl					;
	inc de					;
	dec bc					;
	ld a, b					;
	or c					;
	jr nz, fb_cpy_loop		;
	ret						;

fb_clear_2thirds
	ld hl, FB_ADDR			; target buffer
	ld bc, &1000			; 4096 bytes
	ld d, 0					;
fb_clr_loop
	ld (hl), d				;
	inc hl					;
	dec bc					;
	ld a, b					;
	or c					;
	jr nz, fb_clr_loop		;
	ret						;

fb_fill_ff_trd0
	ld hl, FB_ADDR			; first hidden third
	ld bc, &0800			; 2048 bytes
	ld d, &ff				;
fb_ff0_loop
	ld (hl), d				;
	inc hl					;
	dec bc					;
	ld a, b					;
	or c					;
	jr nz, fb_ff0_loop		;
	ret						;

fb_fill_00_trd1
	ld hl, FB_ADDR + &0800	; second hidden third, used as black source
	ld bc, &0800			; 2048 bytes
	ld d, 0					;
fb_001_loop
	ld (hl), d				;
	inc hl					;
	dec bc					;
	ld a, b					;
	or c					;
	jr nz, fb_001_loop		;
	ret						;

; Copy first hidden third to first visible screen third using SP as writer.
; Source: FB_ADDR..FB_ADDR+&07ff. Destination: &4000..&47ff.
; 128 loops * 8 pushes * 2 bytes = 2048 bytes.
fb_push_copy_trd0
	di						;
	ld (fb_sp0 + 1), sp		;
	ld hl, FB_ADDR + &0800	;
	ld sp, &4800			;
	ld b, 128				;
fb_pc0_loop
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	djnz fb_pc0_loop		;
fb_sp0
	ld sp, 0				;
	ei						;
	ret						;

; Copy second hidden third to first visible screen third. This is a probe helper
; to alternate black/white sources without clearing the visible screen first.
fb_push_copy_trd1_to_scr0
	di						;
	ld (fb_sp1to0 + 1), sp	;
	ld hl, FB_ADDR + &1000	;
	ld sp, &4800			;
	ld b, 128				;
fb_pc1to0_loop
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	dec hl					;
	ld d, (hl)				;
	dec hl					;
	ld e, (hl)				;
	push de					;
	djnz fb_pc1to0_loop		;
fb_sp1to0
	ld sp, 0				;
	ei						;
	ret						;

fb_probe_alt_copy0
	ld a, (fb_probe_phase)	;
	xor 1					;
	ld (fb_probe_phase), a	;
	call fb_delay_forward0	;
	or a					;
	jp z, fb_forward_copy_trd1_to_scr0	;
	jp fb_forward_copy_trd0	;

fb_delay_forward0
	ld b, 255				; about 15 raster lines
fb_fdly0_loop1
	djnz fb_fdly0_loop1		;
	ld b, 255				; about 30 raster lines total
fb_fdly0_loop2
	djnz fb_fdly0_loop2		;
	ld b, 255				; about 45 raster lines total
fb_fdly0_loop3
	djnz fb_fdly0_loop3		;
	ld b, 255				; about 59 raster lines total
fb_fdly0_loop4
	djnz fb_fdly0_loop4		;
	ld b, 170				; final tune, about 10 raster lines
fb_fdly0_loop5
	djnz fb_fdly0_loop5		;
	ld b, 235				; final tune, about 13.6 raster lines
fb_fdly0_loop6
	djnz fb_fdly0_loop6		;
	ret						;

; Copy first hidden third to first visible screen third, forward in memory.
; SP is used as source reader and HL as destination writer.
fb_forward_copy_trd0
	di						;
	ld (fb_fsp0 + 1), sp	;
	ld sp, FB_ADDR			;
	ld hl, &4000			;
	ld b, 128				;
fb_fc0_loop
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	djnz fb_fc0_loop		;
fb_fsp0
	ld sp, 0				;
	ei						;
	ret						;

; Copy second hidden third to first visible screen third, forward in memory.
fb_forward_copy_trd1_to_scr0
	di						;
	ld (fb_fsp1to0 + 1), sp	;
	ld sp, FB_ADDR + &0800	;
	ld hl, &4000			;
	ld b, 128				;
fb_fc1to0_loop
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	djnz fb_fc1to0_loop		;
fb_fsp1to0
	ld sp, 0				;
	ei						;
	ret						;

; Copy the whole 4K hidden viewport to the first two visible thirds, forward.
fb_forward_copy_2thirds
	di						;
	ld (fb_fsp2 + 1), sp	;
	ld sp, FB_ADDR			;
	ld hl, &4000			;
	ld c, 2					; two 2K thirds
fb_fc2_part
	ld b, 128				;
fb_fc2_loop
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	pop de					;
	ld (hl), e				;
	inc hl					;
	ld (hl), d				;
	inc hl					;
	djnz fb_fc2_loop		;
	dec c					;
	jr nz, fb_fc2_part		;
fb_fsp2
	ld sp, 0				;
	ei						;
	ret						;

; Probe helper: cycle blank, delayed first-third copy, hold.
fb_probe_trd0_toggle
	ld a, (fb_probe_phase)	;
	or a					;
	jr z, fb_probe_blank0	;
	cp 1					;
	jr z, fb_probe_copy0	;
	xor a					;
	ld (fb_probe_phase), a	;
	ret						;
fb_probe_blank0
	call cle_trd0			;
	ld a, 1					;
	ld (fb_probe_phase), a	;
	ret						;
fb_probe_copy0
	ld a, 2					;
	ld (fb_probe_phase), a	;
	call fb_delay_copy0		;
	jp fb_push_copy_trd0		;

fb_delay_copy0
	ld b, 255				; about 15 raster lines
fb_dly0_loop1
	djnz fb_dly0_loop1		;
	ld b, 255				; about 30 raster lines total
fb_dly0_loop2
	djnz fb_dly0_loop2		;
	ld b, 255				; about 45 raster lines total
fb_dly0_loop3
	djnz fb_dly0_loop3		;
	ld b, 255				; about 60 raster lines total
fb_dly0_loop4
	djnz fb_dly0_loop4		;
	ld b, 255				; about 75 raster lines total
fb_dly0_loop5
	djnz fb_dly0_loop5		;
	ld b, 255				; about 89 raster lines total
fb_dly0_loop6
	djnz fb_dly0_loop6		;
	ld b, 255				; about 104 raster lines total
fb_dly0_loop7
	djnz fb_dly0_loop7		;
	ld b, 7					; final fine tune, about 0.4 raster lines
fb_dly0_loop8
	djnz fb_dly0_loop8		;
	ret						;

; Fill the 4K frame buffer with a simple changing pattern for copy tests.
fb_fill_pattern
	ld hl, FB_ADDR			; target buffer
	ld bc, &1000			; 4096 bytes
	ld a, (fb_pat)			;
	inc a					;
	ld (fb_pat), a			;
	ld d, a					;
fb_fil_loop
	ld (hl), d				;
	inc hl					;
	dec bc					;
	ld a, b					;
	or c					;
	jr nz, fb_fil_loop		;
	ret						;

fb_pat defb 0
fb_probe_phase defb 0
